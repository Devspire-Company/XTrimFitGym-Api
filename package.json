{
  "name": "xtrimfitnessgym-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:offline": "expo start --offline",
    "start:online": "expo start",
    "start:tunnel": "expo start --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "build:android": "eas build --platform android --profile preview",
    "build:android:prod": "eas build --platform android --profile production",
    "postinstall": "node node_modules/patch-package/index.js",
    "generate": "graphql-codegen --config codegen.ts",
    "generate:watch": "graphql-codegen --config codegen.ts --watch",
    "generate:schema": "graphql-codegen --config codegen-schema-files.ts",
    "manual:member": "node scripts/member-manual-gen/generate-member-manual.mjs"
  },
  "dependencies": {
    "@apollo/client": "^4.0.9",
    "@clerk/clerk-expo": "^2.19.31",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@reduxjs/toolkit": "^2.10.1",
    "babel-plugin-module-resolver": "^5.0.3",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.10",
    "expo-crypto": "~15.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "graphql": "^16.12.0",
    "nativewind": "^4.2.1",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-signature-canvas": "^5.0.2",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "rxjs": "^7.8.1",
    "tailwindcss": "^3.4.18"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.1.0",
    "@graphql-codegen/typescript": "^5.0.5",
    "@graphql-codegen/typescript-operations": "^5.0.5",
    "@graphql-codegen/typescript-react-apollo": "^4.3.3",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "expo-module-scripts": "^5.0.7",
    "patch-package": "^8.0.1",
    "start": "file:./scripts/npx-start-shim",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "@react-native-community/datetimepicker",
        "react-native-safe-area-context",
        "expo",
        "expo-auth-session",
        "expo-camera",
        "expo-constants",
        "expo-crypto",
        "expo-font",
        "expo-haptics",
        "expo-image",
        "expo-image-picker",
        "expo-linear-gradient",
        "expo-linking",
        "expo-network",
        "expo-router",
        "expo-splash-screen",
        "expo-status-bar",
        "expo-symbols",
        "expo-system-ui",
        "expo-web-browser"
      ]
    }
  },
  "overrides": {
    "react-server-dom-webpack": "19.0.4"
  },
  "private": true
}
